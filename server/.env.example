# Atomberg Portal — server configuration.
# Copy to `.env` (or export these vars) to activate the real integrations.
# With none set, the portal runs fully on local auth with notifications recorded
# as "skipped" in the Notifications log.

# --- Core ---
PORT=4000
AUTH_SECRET=change-me-to-a-long-random-string
# Public URL of the web app — used for Teams deep links and the SSO redirect home.
APP_BASE_URL=http://localhost:5173

# --- 5.1 Microsoft Entra ID (Azure AD) SSO ---
# Azure portal → App registrations → your app.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Must be registered as a redirect URI (Web platform) on the app registration.
AZURE_REDIRECT_URI=http://localhost:4000/api/auth/sso/callback
# Graph delegated scopes (space separated). Add GroupMember.Read.All for role mapping.
AZURE_SCOPES=User.Read GroupMember.Read.All
# AAD security-group object IDs → portal role (membership in neither = employee).
AZURE_ADMIN_GROUP_ID=
AZURE_MANAGER_GROUP_ID=

# --- 5.2 Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Atomberg Portal <no-reply@atomberg.com>

# --- 5.2 Microsoft Teams ---
# Teams is configured in-app: sign in as admin → Integrations → paste the
# channel webhook URL. This env value is only an optional default.
TEAMS_WEBHOOK_URL=
